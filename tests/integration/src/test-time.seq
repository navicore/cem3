# Test time operations

: test-time-now ( -- )
  # time.now returns seconds since epoch, should be > 1700000000 (year ~2023)
  time.now 1700000000 i.> test.assert
;

: test-time-nanos ( -- )
  # time.nanos returns monotonic nanoseconds, should be positive
  time.nanos 0 i.> test.assert
;

: test-time-nanos-monotonic ( -- )
  # Two calls should be non-decreasing
  time.nanos
  time.nanos
  swap i.>= test.assert
;

: test-time-sleep ( -- )
  # Sleep 1ms, verify time advanced
  time.nanos
  1 time.sleep-ms
  time.nanos
  swap i.> test.assert
;
